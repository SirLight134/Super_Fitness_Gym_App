# App
APP_NAME=super-fitness-api
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration (for local development with Docker)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=super-fitness_db
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true

# S3 Configuration
S3_ENDPOINT=https://s3.eu-west-1.amazonaws.com
S3_REGION=auto
S3_ACCESS_KEY=tid_iXkKIJocKybn...
S3_SECRET_KEY=tsec_diEmTlarViL...
S3_BUCKET_NAME=backet-super-fitness
IMAGE_PROXY_URL=https://example.com/images

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=604800 # 7 days in seconds

# API
API_PREFIX=api
API_VERSION=v1

# Cors
CORS_ORIGIN=*  # change this in production

# Logging
LOG_LEVEL=info # error, warn, info, debug, verbose
LOG_RETENTION_DAYS=14 # Keep logs for 14 days
LOG_MAX_SIZE=20m # Max file size 20MB
NODE_ENV=development # Affects log verbosity